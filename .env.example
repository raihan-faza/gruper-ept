# =============================================================================
# Scriptsea — Root .env
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_HOST_PORT=3000
JWT_SECRET_KEY=secret
BETTER_AUTH_SECRET=auth-secret
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret
RESEND_API_KEY=re_your_api_key_here
INVITATION_CODE=GRUPER2026

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
GATEWAY_PORT=8080
GATEWAY_HOST_PORT=8080

# ---------------------------------------------------------------------------
# user_service (gRPC)
# ---------------------------------------------------------------------------
USER_SERVICE_PORT=3000
USER_DB_USER=user
USER_DB_PASSWORD=1234
USER_DB_NAME=user_service_db

# ---------------------------------------------------------------------------
# wallet_service (gRPC)
# ---------------------------------------------------------------------------
WALLET_SERVICE_PORT=50051
WALLET_DB_USER=wallet
WALLET_DB_PASSWORD=1234
WALLET_DB_NAME=wallet_db

# ---------------------------------------------------------------------------
# expense_service (gRPC)
# ---------------------------------------------------------------------------
EXPENSE_SERVICE_PORT=50053
EXPENSE_DB_USER=expense
EXPENSE_DB_PASSWORD=1234
EXPENSE_DB_NAME=expense_service

# ---------------------------------------------------------------------------
# Redis (shared by wallet_service)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=1234

# ---------------------------------------------------------------------------
# llm_job_service (gRPC)
# ---------------------------------------------------------------------------
LLM_SERVICE_PORT=50057
GEMINI_API_KEY=your_gemini_api_key_here
OPEN_ROUTER_API_KEY=your_open_router_api_key_here
LLM_ACCESS_KEY=YES
LLM_DB_USER=user
LLM_DB_PASSWORD=password
LLM_DB_NAME=llm_job_db

# ---------------------------------------------------------------------------
# report_service (gRPC / Bun)
# ---------------------------------------------------------------------------
REPORT_SERVICE_PORT=3030
STORAGE_ENDPOINT=https://your-object-storage-url.com
STORAGE_REGION=your-region
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=your-bucket
WALLET_SERVICE_TOKEN=your-wallet-service-token
